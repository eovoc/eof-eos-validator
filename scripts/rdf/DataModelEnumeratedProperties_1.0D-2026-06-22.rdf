<rdf:Description rdf:about="https://earth.esa.int/concepts/concept_scheme/spectralrangetype">
	<dct:title xml:lang="en">Spectral Range Types</dct:title>
	<dct:description>None</dct:description>
	<skos:changeNote>2026/06/04 - Initial version</skos:changeNote>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/3fb62d2c-7bc6-420c-8202-1d4faff77540">
	<skos:prefLabel>UV</skos:prefLabel>
	<skos:definition>Ultraviolet: 10 nm &lt; λ &lt; 400 nm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/38a7b3e1-5d88-40fb-b048-2959cbbb586d">
	<skos:prefLabel>VIS</skos:prefLabel>
	<skos:definition>Visible: 400 nm &lt; λ &lt; 700 nm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/1e43dd7c-a9fe-4825-a5a9-8e7b3c7ca69d">
	<skos:prefLabel>IR</skos:prefLabel>
	<skos:definition>Infrared: 0.7 μm &lt; λ &lt; 1000 μm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/8963e65f-35a3-497d-b46f-5a5db0fcdf77">
	<skos:prefLabel>NIR</skos:prefLabel>
	<skos:definition>Near Infrared: 0.7 μm &lt; λ &lt; 1.4 μm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/6ef2b92f-a4d8-48ba-a6b6-4e9e28c6b2f5">
	<skos:prefLabel>SWIR</skos:prefLabel>
	<skos:definition>Short Wavelength Infrared: 1.4 μm &lt; λ &lt; 3 μm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/0948eb64-80f7-4e34-8b3e-5bf138c83010">
	<skos:prefLabel>MWIR</skos:prefLabel>
	<skos:definition>Medium Wavelength Infrared: 3 μm &lt; λ &lt; 5 μm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/5c8d300b-6965-4ca9-8ca8-29f0e4c5a4bd">
	<skos:prefLabel>TIR</skos:prefLabel>
	<skos:definition>Thermal Infrared (Long Wavelength Infrared - LWIR) : 8 μm &lt; λ &lt; 15 μm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/513a3858-4269-40ff-8b6e-746865ef809e">
	<skos:prefLabel>FIR</skos:prefLabel>
	<skos:definition>Far Infrared: 15 μm &lt; λ &lt; 1 mm</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/6dd97e98-8282-430e-aca9-828cd6a3b834">
	<skos:prefLabel>MW</skos:prefLabel>
	<skos:definition>Microwaves: 1 mm &lt; λ &lt; 1 m</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/15a6c09e-4247-47ab-90df-306c30f67467">
	<skos:prefLabel>RW</skos:prefLabel>
	<skos:definition>Radio Waves: λ &gt; 1 m</skos:definition>
</rdf:Description>

<rdf:Description rdf:about="https://earth.esa.int/concept/3fb62d2c-7bc6-420c-8202-1d4faff77540">
	<rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
</rdf:Description>

